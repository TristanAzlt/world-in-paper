AUTH_SECRET="" # Added by `npx auth secret`. Read more: https://cli.authjs.dev
AUTH_TRUST_HOST=true
HMAC_SECRET_KEY='some-secret' # create this by running `openssl rand -base64 32`
AUTH_URL='' # For testing this should be your NGROK URL and for production this should be your production URL
NEXT_PUBLIC_APP_ID='app_1234567890' # APP ID from the developer portal
RP_SIGNING_KEY='' # RP signing key from the developer portal
RP_ID='' # RP ID from the developer portal
NEXT_PUBLIC_UNISWAP_API_KEY='' # Uniswap trade API key
NEXT_PUBLIC_BACKEND_URL='http://localhost:3001' # Backend API URL (or ngrok URL)
NEXT_PUBLIC_CONTRACT_ADDRESS='' # WorldInPaper contract address on World Chain
NEXT_PUBLIC_WORLD_RPC='https://worldchain-mainnet.g.alchemy.com/public' # World Chain RPC (optional, defaults to public)
