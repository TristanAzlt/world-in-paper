# Environment
NODE_ENV=development
PORT=3000

# On-chain config (test values)
RPC_URL=https://worldchain-mainnet.g.alchemy.com/v2/xxxx
CONTRACT_ADDRESS=0x1111111111111111111111111111111111111111

# Redis (local test)
REDIS_URL=redis://127.0.0.1:6379

# HTTP behavior
REQUEST_TIMEOUT_MS=20000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
BODY_LIMIT=10kb

# CORS
# Use * for local tests, replace with frontend URL in production.
CORS_ORIGIN=*
